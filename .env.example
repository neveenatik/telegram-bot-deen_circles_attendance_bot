# Telegram token from @BotFather
BOT_TOKEN=your_bot_token_here

# Optional: secret token to verify incoming webhook requests (any random string)
WEBHOOK_SECRET=

# Optional: group ID where feedback messages are sent (negative number for groups)
FEEDBACK_GROUP_ID=

# Supabase (required in production, omit to use local file storage in dev)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
